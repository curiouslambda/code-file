{
  "columns": [
    {
      "column_name": "id",
      "data_type": "String",
      "required": "Yes",
      "description": "문서의 고유 식별자입니다. 시스템 전체에서 유일해야 합니다. (UUID, 콘텐츠 해시 등)",
      "example": "abc-123-def-456"
    },
    {
      "column_name": "source_type",
      "data_type": "String (Enum 권장)",
      "required": "Yes",
      "description": "데이터의 종류를 나타내는 코드입니다. (예: NEWS, SOCIAL_MEDIA, GOV_REPORT 등 일관된 값 사용)",
      "example": "NEWS"
    },
    {
      "column_name": "source_name",
      "data_type": "String",
      "required": "Yes",
      "description": "데이터의 구체적인 출처명입니다.",
      "example": "로이터"
    },
    {
      "column_name": "source_url",
      "data_type": "String (URL)",
      "required": "Yes",
      "description": "원본 데이터의 웹 주소입니다. 유효한 URL 형식이어야 합니다.",
      "example": "https://www.reuters.com/markets/..."
    },
    {
      "column_name": "author_name",
      "data_type": "String",
      "required": "선택",
      "description": "기사 작성자, 게시물 작성자, 논문 저자 등. 항상 존재하지 않을 수 있습니다.",
      "example": "John Doe"
    },
    {
      "column_name": "publication_timestamp_utc",
      "data_type": "Datetime (ISO 8601 String)",
      "required": "Yes",
      "description": "데이터가 게시/발표된 시간입니다. UTC 기준으로 ISO 8601 형식을 권장합니다. (YYYY-MM-DDTHH:MM:SSZ)",
      "example": "2025-05-20T10:30:00Z"
    },
    {
      "column_name": "retrieval_timestamp_utc",
      "data_type": "Datetime (ISO 8601 String)",
      "required": "Yes",
      "description": "시스템이 데이터를 수집한 시간입니다. UTC 기준으로 ISO 8601 형식을 권장합니다.",
      "example": "2025-05-20T10:35:00Z"
    },
    {
      "column_name": "event_timestamp_utc",
      "data_type": "Datetime (ISO 8601 String)",
      "required": "선택",
      "description": "데이터가 설명하는 실제 사건/이벤트 발생 시간입니다. 게시 시간과 다를 경우에 사용합니다. UTC 기준 ISO 8601 형식.",
      "example": "2025-05-19T15:00:00Z"
    },
    {
      "column_name": "title",
      "data_type": "String",
      "required": "Yes",
      "description": "기사 제목, 보고서 제목, 트윗 요약 등 데이터의 제목입니다.",
      "example": "연준, 금리 동결 시그널 속 매파적 발언 주목"
    },
    {
      "column_name": "language",
      "data_type": "String (ISO 639-1 Code)",
      "required": "Yes",
      "description": "데이터의 언어 코드입니다. (예: ko, en)",
      "example": "ko"
    },
    {
      "column_name": "cleaned_content",
      "data_type": "String (Text/CLOB)",
      "required": "Yes",
      "description": "LLM 입력 또는 임베딩 생성을 위해 정제된 텍스트 내용입니다. (HTML 태그 제거, 불필요한 공백 제거 등) (내용이 길 경우 관리 주의)",
      "example": "연방준비제도(연준)가 다음 FOMC 회의에서..."
    },
    {
      "column_name": "keywords",
      "data_type": "List of Strings (문자열 변환)",
      "required": "선택 (권장)",
      "description": "문서의 핵심 키워드 목록입니다. 스프레드시트에서는 쉼표로 구분된 문자열(e.g., 금리,FOMC,연준) 또는 JSON 문자열(e.g., [금리, FOMC, 연준])로 저장할 수 있습니다.",
      "example": "연준,FOMC,기준금리,매파적"
    },
    {
      "column_name": "summary",
      "data_type": "String (Text)",
      "required": "선택",
      "description": "문서 내용 요약본입니다. (LLM으로 생성 가능)",
      "example": "연준의 금리 동결 가능성이 높으나..."
    },
    {
      "column_name": "mentioned_tickers",
      "data_type": "List of Strings (문자열 변환)",
      "required": "선택",
      "description": "문서 내에 언급된 주식 종목 코드 목록입니다. (예: 005930.KS,AAPL) 표준화된 티커 형식을 사용합니다. (쉼표 구분 또는 JSON 문자열)",
      "example": "^IXIC,^GSPC"
    },
    {
      "column_name": "mentioned_companies",
      "data_type": "List of Strings (문자열 변환)",
      "required": "선택",
      "description": "언급된 기업명 목록입니다. 정규화된 이름을 사용하는 것이 좋습니다. (쉼표 구분 또는 JSON 문자열)",
      "example": "Federal Reserve,JP Morgan"
    },
    {
      "column_name": "mentioned_persons",
      "data_type": "List of Strings (문자열 변환)",
      "required": "선택",
      "description": "언급된 인물명 목록입니다. (쉼표 구분 또는 JSON 문자열)",
      "example": "Jerome Powell,Christine Lagarde"
    },
    {
      "column_name": "mentioned_locations",
      "data_type": "List of Strings (문자열 변환)",
      "required": "선택",
      "description": "언급된 지역/국가명 목록입니다. (쉼표 구분 또는 JSON 문자열)",
      "example": "United States,Eurozone"
    },
    {
      "column_name": "mentioned_economic_indicators",
      "data_type": "List of Strings (문자열 변환)",
      "required": "선택",
      "description": "언급된 경제 지표 목록입니다. (예: GDP 성장률,소비자물가지수) (쉼표 구분 또는 JSON 문자열)",
      "example": "interest_rate,inflation,unemployment_rate"
    },
    {
      "column_name": "industry_sectors",
      "data_type": "List of Strings (문자열 변환)",
      "required": "선택",
      "description": "관련된 산업 분야 목록입니다. (예: Technology,Finance) 미리 정의된 분류 체계를 따르는 것이 좋습니다. (쉼표 구분 또는 JSON 문자열)",
      "example": "Finance,Central Banking"
    },
    {
      "column_name": "sentiment_score",
      "data_type": "Float",
      "required": "선택",
      "description": "내용의 감성 점수입니다. (예: -1.0 ~ 1.0, 긍정/부정/중립) 감성 분석 모델을 통해 추출합니다.",
      "example": "-0.3"
    },
    {
      "column_name": "event_type",
      "data_type": "String (Enum 권장)",
      "required": "선택",
      "description": "문서가 나타내는 주요 이벤트 유형입니다. (예: EARNINGS_RELEASE, POLICY_CHANGE 등 일관된 값 사용)",
      "example": "POLICY_CHANGE_HINT"
    },
    {
      "column_name": "original_format",
      "data_type": "String",
      "required": "Yes",
      "description": "original_content의 원본 데이터 형식입니다. (예: HTML, PDF, JSON, PLAIN_TEXT)",
      "example": "HTML"
    },
    {
      "column_name": "cleaned_content_hash",
      "data_type": "String",
      "required": "선택",
      "description": "cleaned_content의 해시값입니다. (예: SHA256) 중복 데이터 식별 및 내용 변경 감지에 유용합니다.",
      "example": "sha256_hash_of_cleaned_content_value"
    },
    {
      "column_name": "processing_status",
      "data_type": "String (Enum 권장)",
      "required": "Yes",
      "description": "데이터 처리 파이프라인에서의 현재 상태를 나타냅니다. (예: RAW, CLEANED, EMBEDDED, INDEXED, ERROR 등)",
      "example": "EMBEDDED"
    }
  ]
}